{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "firewall": {
      "type": "local",
      "command": [
        "agent-firewall",
        "mcp"
      ],
      "enabled": true,
      "timeout": 30000
    }
  },
  "permission": {
    "bash": "deny",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      ".ssh/*": "deny",
      ".ssh/authorized_keys": "deny",
      ".ssh/id_rsa": "deny",
      ".ssh/id_ed25519": "deny",
      "*.pem": "deny",
      "*.key": "deny",
      "*.p12": "deny",
      "*.pfx": "deny",
      "*.keystore": "deny",
      ".aws/credentials": "deny",
      ".gnupg/*": "deny",
      ".npmrc": "deny",
      ".pypirc": "deny",
      ".netrc": "deny",
      ".dircolors": "deny"
    },
    "external_directory": {
      "~/.ssh/*": "deny",
      "~/.aws/*": "deny",
      "~/.gnupg/*": "deny",
      "~/.config/*": "deny",
      "~/.npmrc": "deny",
      "~/.pypirc": "deny",
      "~/.netrc": "deny",
      "~/*.pem": "deny",
      "~/*.key": "deny",
      "~/*.env": "deny"
    },
    "webfetch": {
      "*": "allow"
    }
  }
}
