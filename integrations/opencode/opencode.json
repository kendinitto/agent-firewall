{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      ".ssh/*": "deny",
      ".ssh/authorized_keys": "deny",
      ".ssh/id_rsa": "deny",
      ".ssh/id_ed25519": "deny",
      "*.pem": "deny",
      "*.key": "deny",
      "*.p12": "deny",
      "*.pfx": "deny",
      "*.keystore": "deny",
      ".aws/credentials": "deny",
      ".gnupg/*": "deny",
      ".npmrc": "deny",
      ".pypirc": "deny",
      ".netrc": "deny",
      ".dircolors": "deny"
    },
    "bash": {
      "*": "ask",
      "curl * | *bash": "deny",
      "curl * | *sh": "deny",
      "wget * | *bash": "deny",
      "wget * | *sh": "deny",
      "cat *.ssh/*": "deny",
      "cat *.pem": "deny",
      "cat *.key": "deny",
      "cat *.env": "deny",
      "cat *.aws/*": "deny",
      "cat *.npmrc": "deny",
      "cat *.pypirc": "deny",
      "cat *.netrc": "deny",
      "cat *.gnupg/*": "deny",
      "ls -la *.ssh/*": "deny",
      "ssh *": "ask",
      "scp *": "ask",
      "git *": "allow",
      "npm *": "allow",
      "yarn *": "allow",
      "pip *": "allow",
      "pip3 *": "allow",
      "cargo *": "allow",
      "go *": "allow",
      "make *": "allow",
      "pytest *": "allow",
      "python *": "allow",
      "node *": "allow",
      "npx *": "allow",
      "bun *": "allow",
      "grep *": "allow",
      "find *": "allow",
      "ls *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "diff *": "allow",
      "ruff *": "allow",
      "mypy *": "allow",
      "docker *": "ask",
      "chmod *": "ask",
      "chown *": "ask",
      "rm *": "ask",
      "mv *": "ask",
      "cp *": "allow",
      "mkdir *": "allow",
      "touch *": "allow"
    },
    "external_directory": {
      "~/.ssh/*": "deny",
      "~/.aws/*": "deny",
      "~/.gnupg/*": "deny",
      "~/.config/*": "deny",
      "~/.npmrc": "deny",
      "~/.pypirc": "deny",
      "~/.netrc": "deny",
      "~/*.pem": "deny",
      "~/*.key": "deny",
      "~/*.env": "deny"
    },
    "webfetch": {
      "*": "allow"
    }
  }
}
